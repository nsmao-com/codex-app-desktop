<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="nicecodex.exe"
        Arguments=""
        InstallLocation="C:\Program Files\Nice Codex\Nice Codex">
    </Installer>
    <PackageInformation
        PackageName="Nice Codex"
        PackageDisplayName="Nice Codex"
        PublisherName="CN=Nice Codex"
        PublisherDisplayName="Nice Codex"
        Version="0.1.0.0"
        PackageDescription="A lightweight Codex-compatible desktop client.">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="com.nicecodex.desktop"
                Description="A lightweight Codex-compatible desktop client."
                DisplayName="Nice Codex"
                ExecutableName="nicecodex.exe"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>Nice Codex</DisplayName>
            <PublisherDisplayName>Nice Codex</PublisherDisplayName>
            <Description>A lightweight Codex-compatible desktop client.</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="nicecodex.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
